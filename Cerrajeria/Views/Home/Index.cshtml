@{
    ViewData["Title"] = "Inicio";
}

<div class="text-center">
    <h1>Cerrajería Fernando</h1>
    <p>Bienvenido, ¿qué necesitás hoy?</p>
</div>

@if (User.Identity?.IsAuthenticated == true)
{
    @if (User.IsInRole("Administrador"))
    {
        <div class="row mt-4">
            <h3>Panel de Administrador</h3>
            <div class="col-md-4">
                <div class="card text-center p-3">
                    <h5>Clientes</h5>
                    <a asp-controller="Clientes" asp-action="Index" class="btn btn-primary">Gestionar Clientes</a>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card text-center p-3">
                    <h5>Servicios</h5>
                    <a asp-controller="Servicios" asp-action="Index" class="btn btn-primary">Gestionar Servicios</a>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card text-center p-3">
                    <h5>Reservas</h5>
                    <a asp-controller="Reservas" asp-action="Index" class="btn btn-primary">Gestionar Reservas</a>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="row mt-4 justify-content-center">
            <h3 class="text-center">¿Qué querés hacer?</h3>
            <div class="col-md-4">
                <div class="card text-center p-3">
                    <h5>Nueva Reserva</h5>
                    <a asp-controller="Reservas" asp-action="Create" class="btn btn-primary">Hacer una reserva</a>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card text-center p-3">
                    <h5>Mis Reservas</h5>
                    <a asp-controller="Reservas" asp-action="Index" class="btn btn-secondary">Ver mis reservas</a>
                </div>
            </div>
        </div>
    }
}
else
{
    <div class="text-center mt-4">
        <a asp-controller="Login" asp-action="Index" class="btn btn-primary btn-lg">Iniciá sesión para reservar</a>
    </div>
}