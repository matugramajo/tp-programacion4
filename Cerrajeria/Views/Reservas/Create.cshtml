@model Cerrajeria.Models.Reserva

@{
    ViewData["Title"] = "Nueva Reserva";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-8 col-lg-6">
        <div class="card border-0 shadow-sm" style="border-radius: 12px;">
            <div class="card-header bg-dark text-white py-3" style="border-radius: 12px 12px 0 0;">
                <h4 class="mb-0 fw-bold"><i class="bi bi-calendar-plus-fill me-2"></i>Nueva Reserva</h4>
            </div>
            <div class="card-body p-4">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    
                    <div class="mb-3">
                        <label asp-for="Nombre" class="form-label fw-bold"></label>
                        <input asp-for="Nombre" class="form-control" placeholder="Ingresá tu nombre" />
                        <span asp-validation-for="Nombre" class="text-danger"></span>
                    </div>
                    
                    <div class="mb-3">
                        <label asp-for="Telefono" class="form-label fw-bold"></label>
                        <input asp-for="Telefono" class="form-control" placeholder="Ej: 11 2345-6789" />
                        <span asp-validation-for="Telefono" class="text-danger"></span>
                    </div>
                    
                    <div class="mb-3">
                        <label asp-for="Direccion" class="form-label fw-bold"></label>
                        <input asp-for="Direccion" class="form-control" placeholder="Calle, número, localidad" />
                        <span asp-validation-for="Direccion" class="text-danger"></span>
                    </div>
                    
                    <div class="mb-3">
                        <label asp-for="ServicioId" class="form-label fw-bold"></label>
                        <select asp-for="ServicioId" class="form-select" asp-items="ViewBag.ServicioId">
                            <option value="">-- Seleccioná un servicio --</option>
                        </select>
                        <span asp-validation-for="ServicioId" class="text-danger"></span>
                    </div>
                    
                    <div class="mb-3">
                        <label asp-for="FechaHora" class="form-label fw-bold"></label>
                        <input asp-for="FechaHora" class="form-control" />
                        <span asp-validation-for="FechaHora" class="text-danger"></span>
                        <div class="form-text text-muted">
                            Lunes a viernes de 8 a 16 hs. Sábados de 9 a 12 hs.
                        </div>
                    </div>
                    
                    <div class="mb-4">
                        <label asp-for="Observaciones" class="form-label fw-bold"></label>
                        <textarea asp-for="Observaciones" class="form-control" rows="3" placeholder="Detalles adicionales sobre el trabajo..."></textarea>
                        <span asp-validation-for="Observaciones" class="text-danger"></span>
                    </div>
                    
                    <div class="d-flex justify-content-between align-items-center">
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left me-1"></i>Volver
                        </a>
                        <button type="submit" class="btn btn-primary px-4">
                            Confirmar reserva <i class="bi bi-check-circle ms-1"></i>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}